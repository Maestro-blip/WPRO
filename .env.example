# Шаблон env-змінних. Скопіюй цей файл у .env.local і встав свій URL.
# Цей шаблон комітиться у git, реальні значення — ні.

# URL Google Apps Script Web App, який приймає POST з форми RSVP
# і записує рядок у Google-таблицю. Створюється у Apps Script проєкті,
# привʼязаному до таблиці, через Deploy → New deployment → Web app.
NEXT_PUBLIC_SHEET_WEBHOOK_URL=https://script.google.com/macros/s/REPLACE_WITH_YOUR_KEY/exec
